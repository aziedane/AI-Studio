{
  "entities": {
    "Trend": {
      "title": "Trend",
      "description": "Trending topic discovered from various sources (Google Trends, Reddit, YouTube)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the trend" },
        "source": { "enum": ["Google Trends", "Reddit", "YouTube"], "description": "Source platform of the trend" },
        "topic": { "type": "string", "description": "The trending topic or keyword" },
        "viralScore": { "type": "number", "description": "Numeric score indicating virality level" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the trend was recorded" },
        "userId": { "type": "string", "description": "Owner of the trend data" }
      },
      "required": ["id", "source", "topic", "viralScore", "timestamp", "userId"]
    },
    "ContentPiece": {
      "title": "ContentPiece",
      "description": "A piece of content generated by the system with full metadata and status",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the content item" },
        "trendId": { "type": "string", "description": "Reference to the source trend" },
        "title": { "type": "string", "description": "Title of the video/content" },
        "script": { "type": "string", "description": "Full script/narration text" },
        "thumbnailUrl": { "type": "string", "description": "URL to the generated thumbnail image" },
        "videoUrl": { "type": "string", "description": "URL to the rendered video file" },
        "videoStoryboard": { 
          "type": "array", 
          "description": "List of scenes with visuals, audio, and motion instructions",
          "items": { "type": "object" }
        },
        "status": { "type": "string", "enum": ["DISCOVERY", "DRAFTING", "PRODUCTION", "RENDERING", "READY", "PUBLISHED"], "description": "Current status in the production pipeline" },
        "progress": { "type": "number", "description": "Production progress percentage (0-100)" },
        "downloadUrl": { "type": "string", "description": "Direct download link for the final video" },
        "publishedUrl": { "type": "string", "description": "URL of the content on YouTube" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "publishedAt": { "type": "string", "format": "date-time", "description": "Publication timestamp" },
        "userId": { "type": "string", "description": "Owner of the content" }
      },
      "required": ["id", "trendId", "title", "script", "status", "progress", "createdAt", "userId"]
    }
  },
  "firestore": {
    "trends": {
      "schema": "Trend",
      "description": "Collection of discovered trends for the user"
    },
    "contentItems": {
      "schema": "ContentPiece",
      "description": "Collection of generated content items and their production state"
    }
  }
}
